# ── PixelPack 后端环境变量模板 ────────────────────────────────────────
# 用法：在服务器上 `cp server/.env.example server/.env` 后填入真实密钥。
# .env 不进 git、不进镜像，仅由 docker-compose 的 env_file 在运行时注入。
#
# ⚠️ DATABASE_URL 与 UPLOAD_DIR 已在 docker-compose.yml 的 environment 中固定指向
#    /app/data（持久化卷），这里无需也不应覆盖。

# ── GLM 连接（claude-agent-sdk 子进程经 os.environ 继承）──
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_TOKEN=请替换为你的真实 GLM token
ANTHROPIC_MODEL=glm-5.2

# ── 每日资讯定时生成 ──
INTEL_CRON_HOUR=7
INTEL_CRON_MINUTE=0

# ── Agent 检索 / 产出参数 ──
INTEL_SEARCH_LIMIT=40
INTEL_MIN_ARTICLES=4
INTEL_MAX_ARTICLES=6
