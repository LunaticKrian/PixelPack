# ── 新项目站点模板 ────────────────────────────────────────────────
# 接入新项目时复制本文件，把所有 <project> 占位符替换为项目名。
# 接入清单见 docs/technology/260719-nginx部署架构.md §9。

server {
    listen 443 ssl;
    http2 on;
    server_name <project>.airise.site;

    ssl_certificate     /etc/letsencrypt/live/airise.site/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/airise.site/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    root  /var/www/<project>;
    index index.html;
    client_max_body_size 25m;

    # 后端 API / WS：把 <project>-api 换成该项目的后端容器名，端口按需调整
    location /api/ {
        proxy_pass http://<project>-api:8000;
        include /etc/nginx/snippets/proxy.conf;
    }

    # 上传 / 预览文件
    location /uploads/ {
        alias /var/www/<project>-uploads/;
        add_header Content-Disposition "inline";
    }

    # SPA history 回退（非 SPA 项目可删）
    location / {
        try_files $uri $uri/ /index.html;
    }
}

server {
    listen 80;
    server_name <project>.airise.site;
    return 301 https://$host$request_uri;
}
